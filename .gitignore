# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SEO CMS runtime data (mutable "database" — see lib/cms/storage.ts).
# The directory ships via .gitkeep; seo.json is created on first admin save.
/content/cms/seo.json

# CMS media uploads (OG images, favicons). Deliberately NOT under public/ —
# Next.js's production server scans public/ once at startup and won't see
# files written there at runtime, so uploads are served instead by
# app/uploads/[...path]/route.ts, which reads this directory fresh per request.
/content/uploads/*
!/content/uploads/.gitkeep
