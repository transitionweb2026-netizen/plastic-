# Copy this file to .env.local and fill in real values.
# Forms will show a friendly "not configured" message until these are set.

# Formspree form IDs — create forms at https://formspree.io and paste the ID
# (the part after /f/ in the endpoint URL, e.g. https://formspree.io/f/abcd1234 -> abcd1234)
NEXT_PUBLIC_FORMSPREE_CONTACT_ID=
NEXT_PUBLIC_FORMSPREE_QUOTE_ID=
NEXT_PUBLIC_FORMSPREE_NEWSLETTER_ID=

# WhatsApp business number in international format WITHOUT + or spaces,
# e.g. 201025151199 for +20 102 515 1199. Powers the floating WhatsApp button.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Canonical production URL (used for sitemap/robots/OG metadata)
NEXT_PUBLIC_SITE_URL=https://www.giantstorage.com

# SEO CMS admin login (/admin). Falls back to "giant-admin" in dev if unset —
# the login screen shows a loud warning until you set a real password here.
ADMIN_PASSWORD=

# Supabase project backing the CMS (all content/SEO/translations storage).
# SUPABASE_URL: Project Settings -> API -> Project URL
# SUPABASE_SERVICE_ROLE_KEY: Project Settings -> API -> service_role secret
# (server-only — never expose this key to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
